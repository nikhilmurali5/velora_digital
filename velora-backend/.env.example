# ─────────────────────────────────────────────
#  VELORA Backend — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit the real .env to git
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/velora?retryWrites=true&w=majority

# Gmail address used to SEND emails (must match the App Password below)
EMAIL_USER=veloradigital07@gmail.com

# Gmail App Password (16-character code — NOT your Gmail login password)
# How to get it: Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Email address where admin notifications are delivered
ADMIN_EMAIL=veloradigital07@gmail.com

# Port the server listens on locally (Render/Railway override this automatically)
PORT=3000
